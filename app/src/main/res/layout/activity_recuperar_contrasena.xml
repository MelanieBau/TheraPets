<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla principal con fondo blanco -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Cabecera -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/morado_principal"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Botón volver -->
        <ImageButton
            android:id="@+id/btnVolver"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_boton_volver"
            android:src="@drawable/ic_arrow_volver"
            android:contentDescription="Volver" />

        <!-- Título y subtítulo -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recuperar contraseña"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Indica tu correo electronico"
                android:textSize="13sp"
                android:textColor="@color/morado_claro"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>


    <!-- Contenido del formulario -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Campo donde el usuario escribe su email -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/RoundedInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmailRecuperar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Correo electrónico"
                android:inputType="textEmailAddress" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Botón que envía el email de recuperación -->
        <Button
            android:id="@+id/btnEnviarRecuperar"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Enviar email"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/morado_principal"
            app:cornerRadius="12dp" />

        <!-- Botón para volver al login sin hacer nada -->
        <Button
            android:id="@+id/btnVolverLogin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:text="Volver al login"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="@color/morado_principal"
            android:backgroundTint="@color/morado_claro"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>