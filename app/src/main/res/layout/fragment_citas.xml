<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Cabecera morada -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/morado_principal"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mis Citas"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <!-- Pestañas -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        app:tabSelectedTextColor="@color/morado_principal"
        app:tabTextColor="@color/texto_hint"
        app:tabIndicatorColor="@color/morado_principal"
        app:tabBackground="@android:color/transparent"
        app:tabMode="fixed" />

    <!-- Contenido de las pestañas -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Botón agendar nueva cita -->
    <Button
        android:id="@+id/btnNuevaCita"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="16dp"
        android:text="+ Agendar nueva cita"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="@color/morado_oscuro"
        app:cornerRadius="12dp" />

</LinearLayout>