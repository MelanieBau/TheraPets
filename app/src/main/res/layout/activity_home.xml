<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Contenedor de fragments -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="56dp"
        android:clipToPadding="false"
        android:background="@color/white" />

    <!-- Barra inferior con hueco curvo -->
    <com.example.therapets.BottomNavCurved
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/transparent"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@null"
        app:itemTextColor="@color/texto_principal"
        app:labelVisibilityMode="labeled"
        app:itemIconSize="28dp" />

    <!-- Botón central flotante -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAgendar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="28dp"
        android:src="@drawable/boton_agregar"
        android:contentDescription="Agendar cita"
        app:backgroundTint="@color/coral_acento"
        app:tint="@null"
        app:fabSize="auto"
        app:maxImageSize="36dp"
        app:elevation="12dp"
        app:borderWidth="0dp"
        app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Full" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>