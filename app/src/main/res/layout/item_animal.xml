<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Foto del animal a la izquierda -->
        <ImageView
            android:id="@+id/ivFotoAnimalItem"
            android:layout_width="110dp"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/morado_claro" />

        <!-- Barra coral -->
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/coral_acento" />

        <!-- Contenido -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Nombre -->
            <TextView
                android:id="@+id/tvNombreAnimal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del animal"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/texto_principal" />

            <!-- Tipo -->
            <TextView
                android:id="@+id/tvTipoAnimal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo"
                android:textSize="13sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginTop="4dp" />

            <!-- Centro -->
            <TextView
                android:id="@+id/tvCentroAnimal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Centro"
                android:textSize="13sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginTop="2dp" />

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginVertical="10dp" />

            <!-- Botones -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnEditarAnimal"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="Editar"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/morado_oscuro"
                    app:cornerRadius="8dp" />

                <Button
                    android:id="@+id/btnBorrarAnimal"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:text="Borrar"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:textColor="@color/coral_acento"
                    android:backgroundTint="@color/coral_claro"
                    app:cornerRadius="8dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>