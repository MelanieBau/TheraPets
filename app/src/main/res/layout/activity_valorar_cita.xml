<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla principal con fondo blanco -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cabecera morada con nombre del centro -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/morado_principal"
            android:padding="24dp"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Logo TheraPets -->
            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/logo_therapets"
                android:layout_marginBottom="12dp" />

            <!-- Título de la pantalla -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sesion completada"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <!-- Nombre del centro -->
            <TextView
                android:id="@+id/tvCentroValorar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Centro TheraPets"
                android:textSize="13sp"
                android:textColor="@color/morado_claro"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Contenido principal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Pregunta al usuario -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Como te has sentido hoy?"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/texto_principal"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp" />

            <!-- Fila de emojis de estado de animo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <!-- Emoji 1 - Mal -->
                <LinearLayout
                    android:id="@+id/btnMal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😔"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mal"
                        android:textSize="11sp"
                        android:textColor="@color/texto_secundario"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Emoji 2 - Regular -->
                <LinearLayout
                    android:id="@+id/btnRegular"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😐"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Regular"
                        android:textSize="11sp"
                        android:textColor="@color/texto_secundario"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Emoji 3 - Bien -->
                <LinearLayout
                    android:id="@+id/btnBien"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🙂"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bien"
                        android:textSize="11sp"
                        android:textColor="@color/texto_secundario"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Emoji 4 - Muy bien -->
                <LinearLayout
                    android:id="@+id/btnMuyBien"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😊"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Muy bien"
                        android:textSize="11sp"
                        android:textColor="@color/texto_secundario"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Emoji 5 - Genial -->
                <LinearLayout
                    android:id="@+id/btnGenial"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😄"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Genial"
                        android:textSize="11sp"
                        android:textColor="@color/texto_secundario"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Campo de nota opcional -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/RoundedInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNotaValorar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Escribe una nota opcional..."
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Botón guardar valoración -->
            <Button
                android:id="@+id/btnGuardarValoracion"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Guardar valoracion"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/morado_oscuro"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>