<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_therapets">

    <!-- Scroll para el contenido -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnIrInicio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Cabecera verde oscuro -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2D5F4F"
                android:padding="24dp"
                android:paddingBottom="40dp"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¡Solicitud enviada!"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="El centro revisará tu solicitud y te confirmará la cita"
                    android:textSize="14sp"
                    android:textColor="#AAFFFFFF"
                    android:textAlignment="center"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Imagen -->
            <ImageView
                android:id="@+id/ivConfirmacion"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:src="@drawable/solicitud_enviada"
                android:scaleType="fitCenter" />

            <!-- Tarjeta resumen -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Barra verde arriba -->
                    <View
                        android:layout_width="40dp"
                        android:layout_height="4dp"
                        android:background="#4CAF82"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resumen de tu cita"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#2D5F4F"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvResumen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#2E2E2E"
                        android:lineSpacingExtra="6dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <!-- Botones fijos abajo -->
    <Button
        android:id="@+id/btnIrInicio"
        android:layout_width="0dp"
        android:layout_height="46dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:text="Ir al inicio"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2D5F4F"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toTopOf="@id/btnVolverCitas"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnVolverCitas"
        android:layout_width="0dp"
        android:layout_height="46dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="20dp"
        android:text="Ver mis citas"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF82"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>