<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivFotoCentroSeleccion"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:background="#E8F5E9" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvNombreCentroSeleccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Centro TheraPets"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2D5F4F" />

            <TextView
                android:id="@+id/tvDireccionCentroSeleccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Dirección"
                android:textSize="13sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvTelefonoCentroSeleccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📞 Teléfono"
                android:textSize="13sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginVertical="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnVerMaps"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Ver en Maps"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2D5F4F"
                    app:cornerRadius="30dp" />

                <Button
                    android:id="@+id/btnSeleccionarCentro"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="Seleccionar"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#4CAF82"
                    app:cornerRadius="30dp" />

            </LinearLayout>

            <!-- Confirmar hora  -->
            <Button
                android:id="@+id/btnConfirmarHora"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                android:text="Confirmar y continuar"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF82"
                app:cornerRadius="30dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>