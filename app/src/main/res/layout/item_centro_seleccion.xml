<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Foto del centro -->
        <ImageView
            android:id="@+id/ivFotoCentroSeleccion"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:background="@color/morado_claro" />

        <!-- Contenido -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Nombre del centro -->
            <TextView
                android:id="@+id/tvNombreCentroSeleccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Centro TheraPets"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/texto_principal" />

            <!-- Dirección -->
            <TextView
                android:id="@+id/tvDireccionCentroSeleccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Dirección"
                android:textSize="13sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginTop="6dp" />

            <!-- Teléfono -->
            <TextView
                android:id="@+id/tvTelefonoCentroSeleccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📞 Teléfono"
                android:textSize="13sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginTop="4dp" />

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginVertical="12dp" />

            <!-- Botones -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Ver en Google Maps -->
                <Button
                    android:id="@+id/btnVerMaps"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Ver en Maps"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:textColor="@color/morado_principal"
                    android:backgroundTint="@color/morado_claro"
                    app:cornerRadius="12dp" />

                <!-- Seleccionar centro -->
                <Button
                    android:id="@+id/btnSeleccionarCentro"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="Seleccionar"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/morado_oscuro"
                    app:cornerRadius="12dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>