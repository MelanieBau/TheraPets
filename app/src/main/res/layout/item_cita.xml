<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Barra morada izquierda -->
        <View
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="@color/morado_principal" />

        <!-- Contenido -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Fecha y estado -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvFechaCita"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="10 abril · 10:00"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/texto_principal" />

                <!-- Píldora estado -->
                <TextView
                    android:id="@+id/tvEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pendiente"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_estado_cita"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp" />

            </LinearLayout>

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginVertical="10dp" />

            <!-- Centro -->
            <TextView
                android:id="@+id/tvCentroCita"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Centro Barcelona"
                android:textSize="14sp"
                android:textColor="@color/texto_principal"
                android:textStyle="bold" />

            <!-- Cuidador -->
            <TextView
                android:id="@+id/tvCuidadorCita"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cuidador: María"
                android:textSize="13sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginTop="4dp" />

            <!-- Motivo -->
            <TextView
                android:id="@+id/tvMotivoCita"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Motivo: Ansiedad"
                android:textSize="13sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginTop="4dp" />

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginVertical="10dp" />

            <!-- Botón cancelar -->
            <Button
                android:id="@+id/btnCancelarCita"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="Cancelar cita"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/morado_oscuro"
                app:cornerRadius="8dp" />

            <!-- Botón valorar sesión, solo visible en citas completadas -->
            <Button
                android:id="@+id/btnValorarCita"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                android:text="Valorar sesion"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/coral_acento"
                app:cornerRadius="8dp" />


        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>