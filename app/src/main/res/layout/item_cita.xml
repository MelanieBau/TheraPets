<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Cabecera: fecha y estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvFechaCita"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="10/04/2026 a las 10:00"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#3D2A2A" />

            <TextView
                android:id="@+id/tvEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pendiente"
                android:textSize="12sp"
                android:textColor="#9D676C"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp" />

        </LinearLayout>

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginVertical="12dp" />

        <!-- Centro -->
        <TextView
            android:id="@+id/tvCentroCita"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Centro: Barcelona"
            android:textSize="14sp"
            android:textColor="#444444" />

        <!-- Cuidador -->
        <TextView
            android:id="@+id/tvCuidadorCita"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cuidador: María"
            android:textSize="14sp"
            android:textColor="#444444"
            android:layout_marginTop="6dp" />

        <!-- Motivo -->
        <TextView
            android:id="@+id/tvMotivoCita"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Motivo: Ansiedad"
            android:textSize="14sp"
            android:textColor="#444444"
            android:layout_marginTop="6dp" />

        <!-- Botón cancelar (solo en próximas) -->
        <Button
            android:id="@+id/btnCancelarCita"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:text="Cancelar cita"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:textColor="#9D676C"
            android:backgroundTint="#FFF0EC"
            app:cornerRadius="10dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>