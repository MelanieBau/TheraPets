<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cabecera verde -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2D5F4F"
            android:padding="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_boton_volver"
                android:src="@drawable/ic_arrow_volver"
                android:contentDescription="Volver" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Cómo surgió TheraPets?"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginStart="16dp" />

        </LinearLayout>

        <!-- Foto de Chispita circular -->
        <androidx.cardview.widget.CardView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="80dp"
            app:cardElevation="6dp">

            <ImageView
                android:id="@+id/ivChispita"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/logo_therapets" />

        </androidx.cardview.widget.CardView>

        <!-- Tarjeta con el texto -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Barra verde -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:background="#4CAF82"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐾 Chispita 🐾"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#2D5F4F"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TheraPets nace de una historia real y muy cercana. Chispita, mi perrita de 14 años, fue mucho más que una mascota. Siempre fui una persona muy conectada con los animales. De esa experiencia nació la idea de TheraPets. Una aplicación que acerca a las personas que necesitan apoyo emocional con animales y terapeutas especializados, porque creemos que la conexión entre humanos y animales tiene un valor terapéutico real."
                    android:textSize="15sp"
                    android:textColor="#2E2E2E"
                    android:lineSpacingExtra="6dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>