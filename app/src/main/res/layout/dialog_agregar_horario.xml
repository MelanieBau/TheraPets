<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Añadir horario disponible"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#2D5F4F"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Día de la semana"
        android:textSize="13sp"
        android:textColor="#9E9E9E"
        android:layout_marginBottom="6dp" />

    <Spinner
        android:id="@+id/spDia"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_input"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hora disponible"
        android:textSize="13sp"
        android:textColor="#9E9E9E"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvHoraSeleccionada"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Pulsa para elegir hora"
        android:textSize="15sp"
        android:textColor="#9E9E9E"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_input"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnElegirHora"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:text="Elegir hora"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF82"
        app:cornerRadius="30dp" />

</LinearLayout>