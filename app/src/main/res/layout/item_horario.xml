<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Barra morada izquierda -->
        <View
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="@color/morado_principal" />

        <!-- Contenido -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Día de la semana -->
            <TextView
                android:id="@+id/tvDiaHorario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lunes"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/texto_principal" />

            <!-- Hora -->
            <TextView
                android:id="@+id/tvHoraHorario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09:00"
                android:textSize="14sp"
                android:textColor="@color/morado_principal"
                android:layout_marginTop="4dp" />

            <!-- Animales disponibles -->
            <TextView
                android:id="@+id/tvAnimalesHorario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Animales: Max, Luna"
                android:textSize="13sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginTop="4dp" />

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginVertical="10dp" />

            <!-- Botón borrar -->
            <Button
                android:id="@+id/btnBorrarHorario"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="Borrar horario"
                android:textAllCaps="false"
                android:textColor="@color/coral_acento"
                android:backgroundTint="@color/coral_claro"
                app:cornerRadius="8dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>