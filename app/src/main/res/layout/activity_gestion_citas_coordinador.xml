<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla principal con fondo blanco -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Cabecera morada igual que el resto de pantallas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/morado_principal"
        android:padding="20dp">

        <!-- Título de la pantalla -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Citas de mi Centro"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <!-- Lista de citas donde aparecerán los botones de confirmar y cancelar -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCitasCoordinador"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:clipToPadding="false" />

</LinearLayout>