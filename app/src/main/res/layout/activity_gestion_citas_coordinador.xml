<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla principal con fondo blanco -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Cabecera morada -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/morado_principal"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Botón volver -->
        <ImageButton
            android:id="@+id/btnVolver"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_boton_volver"
            android:src="@drawable/ic_arrow_volver"
            android:contentDescription="Volver" />

        <!-- Título y subtítulo -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Citas de mi centro"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

        </LinearLayout>

    </LinearLayout>


    <!-- Lista de citas donde aparecerán los botones de confirmar y cancelar -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCitasCoordinador"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:clipToPadding="false" />

</LinearLayout>