<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cabecera con estiloo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/cabecera"
            android:padding="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Botón volver -->
            <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_boton_volver"
                android:src="@drawable/ic_arrow_volver"
                android:contentDescription="Volver" />

            <!-- Título y subtítulo -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Editar datos del animal"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No olvides modificar y guardar los cambios"
                    android:textSize="13sp"
                    android:textColor="@color/morado_claro"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>


        <!-- Formulario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Foto del animal -->
            <ImageView
                android:id="@+id/ivFotoAnimalEditar"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:background="@color/morado_claro"
                android:layout_marginBottom="12dp" />

            <!-- Botón cambiar foto -->
            <Button
                android:id="@+id/btnSeleccionarFotoEditar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:text="Cambiar foto"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:backgroundTint="@color/coral_acento"
                app:cornerRadius="12dp" />

            <!-- Nombre -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/RoundedInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNombreAnimalEditar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nombre del animal"
                    android:inputType="textCapWords" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tipo -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/RoundedInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTipoAnimalEditar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tipo (perro, gato, conejo...)"
                    android:inputType="textCapWords" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Raza -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/RoundedInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRazaAnimalEditar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Raza (ej: Golden Retriever)"
                    android:inputType="textCapWords" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Edad -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/RoundedInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEdadAnimalEditar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Edad (ej: 3 años)"
                    android:inputType="textCapWords" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Especialidad -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/RoundedInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEspecialidadAnimalEditar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Especialidad (ej: Ansiedad y estrés)"
                    android:inputType="textCapWords" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Separador terapeuta -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/morado_claro"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar terapeuta"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/coral_acento"
                android:layout_marginBottom="16dp" />

            <!-- Foto circular terapeuta + campos al lado -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="16dp"
                    app:cardCornerRadius="40dp"
                    app:cardElevation="4dp">

                    <ImageView
                        android:id="@+id/ivFotoTerapeutaEditar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="@color/morado_claro" />

                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/RoundedInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNombreTerapeutaEditar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Nombre"
                            android:inputType="textPersonName" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/RoundedInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEspecialidadTerapeutaEditar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Especialidad"
                            android:inputType="textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Botón cambiar foto terapeuta -->
            <Button
                android:id="@+id/btnSeleccionarFotoTerapeutaEditar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="24dp"
                android:text="Cambiar foto terapeuta"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:backgroundTint="@color/coral_acento"
                app:cornerRadius="12dp" />
            <!-- Botón guardar -->
            <Button
                android:id="@+id/btnGuardarAnimalEditar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Guardar cambios"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/morado_oscuro"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>