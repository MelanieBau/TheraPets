<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Cabecera -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/morado_principal"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!--Titulo coordinador -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Gestionar Coordinadores"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <!-- Boton para añadir coordinador o centro -->
        <Button
            android:id="@+id/btnAgregarCoordinador"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="+ Añadir"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:backgroundTint="@color/coral_acento"
            app:cornerRadius="10dp" />
    </LinearLayout>


    <!-- Lista de coordinadores -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCoordinadores"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:clipToPadding="false" />

</LinearLayout>
