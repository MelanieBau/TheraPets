<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Cabecera morada -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/morado_principal"
        android:padding="20dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agendar cita"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paso 3 de 4 — Selecciona un cuidador"
            android:textSize="13sp"
            android:textColor="@color/morado_claro"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Contenido -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cuidador disponible"
            android:textSize="14sp"
            android:textColor="@color/texto_secundario"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <Spinner
                android:id="@+id/spCuidador"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingHorizontal="16dp" />

        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnSiguiente3"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Siguiente"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/morado_oscuro"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>