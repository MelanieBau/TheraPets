<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cabecera morada -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/morado_principal"
            android:padding="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Botón volver -->
            <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_boton_volver"
                android:src="@drawable/ic_arrow_volver"
                android:contentDescription="Volver" />

            <!-- Título y subtítulo -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Añadir centro"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rellena los datos del centro"
                    android:textSize="13sp"
                    android:textColor="@color/morado_claro"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>


        <!-- Formulario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Foto del centro -->
            <ImageView
                android:id="@+id/ivFotoCentro"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:background="@color/morado_claro"
                android:layout_marginBottom="12dp" />

            <!-- Botón seleccionar foto -->
            <Button
                android:id="@+id/btnSeleccionarFotoCentro"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:text="Seleccionar foto"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:backgroundTint="@color/coral_acento"
                app:cornerRadius="12dp" />

            <!-- Nombre -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/RoundedInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNombreCentro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nombre del centro"
                    android:inputType="textCapWords" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Dirección -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/RoundedInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDireccionCentro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Dirección"
                    android:inputType="textCapWords" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Teléfono -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/RoundedInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTelefonoCentro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Teléfono"
                    android:inputType="phone" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Botón guardar -->
            <Button
                android:id="@+id/btnGuardarCentro"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Guardar centro"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/morado_oscuro"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>