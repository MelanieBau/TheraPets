<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_principal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cabecera con saludo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/fondo_secundario"
            android:padding="24dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSaludo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡Hola!"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/texto_principal" />

            <TextView
                android:id="@+id/tvFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoy es un buen día"
                android:textSize="14sp"
                android:textColor="@color/morado_principal"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Frase motivacional -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/morado_principal">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Frase del día"
                    android:textSize="12sp"
                    android:textColor="@color/morado_claro"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvFrase"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Los animales nos enseñan a vivir el presente"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="italic"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Botón agendar cita -->
        <Button
            android:id="@+id/btnAgendarCita"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:text="Agendar una cita"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/coral_acento"
            app:cornerRadius="16dp" />

        <!-- Próxima cita -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tu próxima cita"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/texto_principal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardProximaCita"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvProximaCitaFecha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sin citas próximas"
                    android:textSize="15sp"
                    android:textColor="@color/texto_principal"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProximaCitaDetalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Agenda tu primera sesión"
                    android:textSize="13sp"
                    android:textColor="@color/texto_hint"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Dato curioso -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/coral_claro">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¿Sabías que..."
                    android:textSize="14sp"
                    android:textColor="@color/coral_acento"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDatoCurioso"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acariciar un perro puede reducir el cortisol hasta un 30%"
                    android:textSize="14sp"
                    android:textColor="@color/texto_principal"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Animales disponibles -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Animales disponibles"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/texto_principal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAnimales"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    </LinearLayout>

</ScrollView>