<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_therapets">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2D5F4F"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="20dp"
            android:paddingTop="40dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvFecha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.8"
                    android:text="Miércoles, 6 mayo"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvSaludo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="¡Hola!"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="60dp"
                android:layout_height="60dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="6dp">

                <ImageView
                    android:id="@+id/ivFotoPerfil"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#4CAF82"
                    android:src="@drawable/perfil_usuario" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Imagen central -->
        <ImageView
            android:id="@+id/ivBienvenida"
            android:layout_width="250dp"
            android:layout_height="180dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/dog_paw_pana"
            android:scaleType="fitCenter" />


        <androidx.cardview.widget.CardView
            android:id="@+id/cardProximaCita"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="45dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:background="#2D5F4F">

                <androidx.cardview.widget.CardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="14dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/ivFotoTerapeutaCita"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="@drawable/terapeuta" />

                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRÓXIMA SESIÓN"
                        android:textSize="10sp"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvProximaCitaFecha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sin sesiones próximas"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>


        <!-- Nuestros animales -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Conoce a nuestros animales"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#2E2E2E"
            android:layout_marginHorizontal="12dp" />

        <HorizontalScrollView
            android:id="@+id/scrollChips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupFiltros"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="12dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:singleLine="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTodos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Todos"
                    app:chipCornerRadius="30dp"
                    android:checkable="true"
                    android:checked="true"
                    app:chipBackgroundColor="@color/chip_color_state"
                    android:textColor="@color/chip_text_color" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPerros"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Perros"
                    app:chipIcon="@drawable/perro"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_color_state"
                    app:chipCornerRadius="30dp"
                    android:textColor="@color/chip_text_color" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipGatos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gatos"
                    app:chipIcon="@drawable/gato"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_color_state"
                    app:chipCornerRadius="30dp"
                    android:textColor="@color/chip_text_color" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipConejos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Conejos"
                    app:chipIcon="@drawable/conejo"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_color_state"
                    app:chipCornerRadius="30dp"
                    android:textColor="@color/chip_text_color" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCaballos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Caballos"
                    app:chipIcon="@drawable/caballo"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_color_state"
                    app:chipCornerRadius="30dp"
                    android:textColor="@color/chip_text_color" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCobayas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cobayas"
                    app:chipIcon="@drawable/cobaya"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/chip_color_state"
                    app:chipCornerRadius="30dp"
                    android:textColor="@color/chip_text_color" />

            </com.google.android.material.chip.ChipGroup>

        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAnimales"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:clipToPadding="false"
            android:layout_marginBottom="20dp"
            android:paddingHorizontal="12dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <!-- Como surgio TheraPets -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardComoSurgio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="45dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#2D5F4F">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¿Cómo surgió TheraPets?"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Conoce nuestra historia aquí"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/como_surgio"
                    android:alpha="0.9"
                    android:scaleType="fitCenter" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>







</ScrollView>