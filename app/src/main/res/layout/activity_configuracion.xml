<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Cabecera morada -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/morado_principal"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Botón volver -->
        <ImageButton
            android:id="@+id/btnVolver"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_boton_volver"
            android:src="@drawable/ic_arrow_volver"
            android:contentDescription="Volver" />

        <!-- Título y subtítulo -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configuración"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gestiona tu cuenta"
                android:textSize="13sp"
                android:textColor="@color/morado_claro"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>


    <!-- Opciones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Cambiar contraseña -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCambiarContrasena"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cambiar contraseña"
                    android:textSize="15sp"
                    android:textColor="@color/texto_principal" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=">"
                    android:textSize="18sp"
                    android:textColor="@color/morado_principal" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Notificaciones -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Notificaciones"
                    android:textSize="15sp"
                    android:textColor="@color/texto_principal" />

                <Switch
                    android:id="@+id/switchNotificaciones"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Cerrar sesión -->
        <Button
            android:id="@+id/btnCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:text="Cerrar sesión"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textColor="@color/morado_principal"
            android:backgroundTint="@color/morado_claro"
            app:cornerRadius="12dp" />

        <!-- Eliminar cuenta -->
        <Button
            android:id="@+id/btnEliminarCuenta"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:text="Eliminar cuenta"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/coral_acento"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>